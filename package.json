{
  "name": "rusty-wedge-golf-scramble",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:vitest": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --project a11y",
    "test:public-privacy": "vitest run --project public-privacy",
    "security:review": "node scripts/security-review.mjs",
    "check": "npm run lint && npm run typecheck && npm run test:vitest",
    "ci": "npm run lint && npm run typecheck && npm run build && npm run test:vitest",
    "ci:gate": "RUN_CI_GATE=1 npm run test:architecture && RUN_CI_GATE=1 npm run test:integration && RUN_CI_GATE=1 npm run test:e2e",
    "db:migrate:ci": "node scripts/with-ci-gate-env.mjs npm run db:migrate",
    "db:seed:ci": "node scripts/with-ci-gate-env.mjs npm run db:seed",
    "test:architecture": "node scripts/architecture-guard.mjs",
    "qa:checklist": "node scripts/print-qa-checklist.mjs",
    "prelaunch": "npm run check && npm run security:review && npm run test:e2e && npm run test:a11y && npm run qa:checklist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:verify-target": "tsx lib/db/verify-migration-target.ts",
    "db:seed": "tsx lib/db/seed.ts",
    "pr": "node scripts/pr-gate.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.4.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
